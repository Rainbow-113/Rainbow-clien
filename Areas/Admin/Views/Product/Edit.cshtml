    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "_Adminlayout";
}

@model Rainbow.Models.ProductDto

<div class="container p-4 border shadow mt-4">
    <div class="row pb-2">
        <h2 class="text-primary">Edit Product</h2>
        <hr />
    </div>

    @* QUAN TRỌNG: Phải có enctype="multipart/form-data" để gửi được File *@
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        @* Giữ các giá trị ẩn để không bị mất khi lưu *@
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImagePath" />

        <div class="row">
            <div class="col-8">
                <div class="mb-3">
                    <label class="form-label">Product Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>


                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="form-label">Price</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                    <div class="col-6 mb-3">
                        <label class="form-label">Category</label>
                        @* Dùng ViewBag đã đổ dữ liệu từ Controller *@
                        <select asp-for="CategoryId" asp-items="@(new SelectList(ViewBag.CategoryList, "Id", "Name"))" class="form-select">
                            <option disabled selected>--Select Category--</option>
                        </select>
                    </div>
                </div>

               <div class="mb-3 form-check form-switch" >
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" id="isActiveSwitch">
                    <label class="form-check-label" for="isActiveSwitch">Kích hoạt sản phẩm (Is Active)</label>
                    <span asp-validation-for="IsActive" class="text-danger"></span>
               </div>

                <div class="mb-3">
                    <label class="form-label">Upload New Image (Optional)</label>
                    <input type="file" name="MainImageFile" class="form-control" />
                </div>
            </div>
            @* Hiển thị ảnh hiện tại bên góc phải *@
            <div class="col-4 text-center">
                <label class="form-label d-block">Current Image</label>
                <img src="~/Browser/images/@Model.ImagePath" width="100%" style="border-radius:5px; border:1px solid #bbb" />
            </div>
            @* anh phụ  *@
            <div class="row mt-3">
                <div class="col-4">
                    <label class="form-label">Sub Image 1</label>
                    <input type="file" asp-for="SubImageFile1" class="form-control" />
                </div>
                <div class="col-4">
                    <label class="form-label">Sub Image 2</label>
                    <input type="file" asp-for="SubImageFile2" class="form-control" />
                </div>
                <div class="col-4">
                    <label class="form-label">Sub Image 3</label>
                    <input type="file" asp-for="SubImageFile3" class="form-control" />
                </div>
            </div>

        </div>






        <div class="row mt-3">
            <div class="col-6">
                <button type="submit" class="btn btn-primary w-100">Update</button>
            </div>
            <div class="col-6">
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Back to List</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}