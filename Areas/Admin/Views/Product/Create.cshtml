@model Rainbow.Models.ProductDto
@{
    Layout = "_Adminlayout";
}
<div>Creat Produc</div>

<div class="container mt-4">
	<div class="card shadow border-0">
		<div class="card-header bg-primary text-white py-3">
			<h5 class="mb-0"><i class="bi bi-plus-circle"></i> Add New Product</h5>
		</div>
		<div class="card-body p-4">


            <form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="row card p-4 shadow-sm">
        <h3 class="mb-4 text-primary">Add New Product</h3>

        <div class="col-md-6 mb-3">
            <label asp-for="Name" class="form-label fw-bold">Product Name</label>
            <input asp-for="Name" class="form-control" placeholder="e.g. Apple Watch Series 9" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label fw-bold">Category</label>
                        <select name="categoryId" class="form-select" asp-for="Category.Id" ">
                <option value="">-- Choose Category --</option>
                @if (ViewBag.Categories != null)
                {
                    foreach (var cat in (IEnumerable<Rainbow.Models.CategoryDto>)ViewBag.Categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="Price" class="form-label fw-bold">Price</label>
                        <input asp-for="Price" type="number" min="1" step="1" class="form-control" placeholder="0.00" />
        </div>

        <div class="col-md-6 mb-3 d-flex align-items-end">
            <div class="form-check form-switch mb-2">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" checked>
                <label class="form-check-label ms-2">Available for sale</label>
            </div>
        </div>

         <div class="col-12 mb-3">
           <label asp-for="Description" class="form-label fw-bold">Mô tả sản phẩm</label>
           <textarea asp-for="Description" class="form-control" rows="4"
            placeholder="Nhập thông tin chi tiết về sản phẩm..."></textarea>
           <span asp-validation-for="Description" class="text-danger"></span>
         </div>


