@model Rainbow.Models.CategoryDto
@{
    Layout = "_Adminlayout";
}
<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Create Category</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form asp-action="Create" method="post" class="row">
            <div class="border p-3">
                @* Hiển thị lỗi tổng quát *@
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-floating py-2 col-12">
                    <input asp-for="Name" class="form-control border-0 shadow" placeholder=" " />
                    <label asp-for="Name" class="ms-2">Category Name</label>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-floating py-2 col-12">
                    <textarea asp-for="Description" class="form-control border-0 shadow" style="height: 100px" placeholder=" "></textarea>
                    <label asp-for="Description" class="ms-2">Description</label>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="py-3 col-12">
                    <div class="form-check form-switch ms-2">
                        <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                        <label class="form-check-label" asp-for="IsActive">Is Active? (Duyệt hiển thị)</label>
                    </div>
                    <span asp-validation-for="IsActive" class="text-danger"></span>
                </div>

                <div class="row pt-2">
                    <div class="col-6 col-md-3">
                        <button type="submit" class="btn btn-primary form-control">Create</button>
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-action="Index" class="btn btn-outline-secondary border form-control">
                            Back to List
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}