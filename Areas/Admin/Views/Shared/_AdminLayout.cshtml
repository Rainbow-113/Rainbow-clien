@{
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - Rainbow</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        .sidebar {
            min-height: 100vh;
            background: #343a40;
            color: white;
        }

            .sidebar a {
                color: #cfd3d7;
                text-decoration: none;
                display: block;
                padding: 15px;
            }

                .sidebar a:hover {
                    background: #495057;
                    color: white;
                }

                .sidebar a.active {
                    background: #0d6efd;
                    color: white;
                }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-2 d-none d-md-block sidebar shadow">
                <div class="position-sticky pt-3">
                    <h4 class="text-center p-3">Rainbow Admin</h4>
                    <hr>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="nav-link">
                                🏠 Dashboard (Home)
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="nav-link">
                                📂 Manage Category
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="nav-link">
                                🛒 Manage Product
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="User" asp-action="Index" class="nav-link">
                                <i class="fa fa-user-circle m-r-10" aria-hidden="true"></i>
                                <span>User</span>
                            </a>
                        </li>
                    </ul>
                    <hr>
                    <a href="/" class="text-info">⬅ Back to Shop</a>
                </div>
            </nav>

            <main class="col-md-10 ms-sm-auto px-md-4 py-4">
                @RenderBody()
                @await RenderSectionAsync("Scripts", required: false)
            </main>
        </div>
    </div>
</body>
</html>
