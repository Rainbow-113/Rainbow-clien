@model Rainbow.Models.ChangePasswordDto
@{
}


<div class="container p-t-100 p-b-100">
    <div class="bor10 p-lr-40 p-t-30 p-b-40 bg0">
        <h4 class="mtext-105 cl2 txt-center p-b-40">
            Hồ Sơ Cá Nhân
        </h4>

        <h2>Đổi mật khẩu</h2>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
<form asp-action="ChangePassword" method="post">
    <div class="form-group">
        <label>Mật khẩu cũ</label>
        <input asp-for="OldPassword" type="password" class="form-control" />
        <span asp-validation-for="OldPassword" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label>Mật khẩu mới</label>
        <input asp-for="NewPassword" type="password" class="form-control" />
        <span asp-validation-for="NewPassword" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label>Xác nhận mật khẩu</label>
        <input asp-for="ConfirmPassword" type="password" class="form-control" />
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
    </div>
    <br />
    <button type="submit" class="btn btn-success">Cập nhật mật khẩu</button>
    <a asp-action="DetailAccount" class="btn btn-secondary">Hủy</a>
</form>

</div>
</div>

